# Diese Datei ist eine Vorlage. Kopiere sie zu `.env.local` und trage
# deine echten Werte ein. `.env.local` wird von Git ignoriert.

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=DEIN_PROJECT_ID

# ID der Appwrite-Funktion für die Kontolöschung (Functions -> account-deletion)
VITE_APPWRITE_FN_ACCOUNT_DELETION=account-deletion
